    {
      "id": "f1a2b3c4-0001-0001-0001-000000000001",
      "name": "Identification",
      "description": {
        "content": "Recognize music or custom audio from a sample or fingerprint.",
        "type": "text/plain"
      },
      "item": [
        {
          "id": "f1a2b3c4-0001-0001-0001-000000000002",
          "name": "Identify a sample",
          "request": {
            "name": "Identify a sample",
            "description": {
              "content": "POST an audio sample or fingerprint with an HMAC-SHA1 signature to identify music or custom audio.",
              "type": "text/plain"
            },
            "url": {
              "raw": "https://identify-eu-west-1.acrcloud.com/v1/identify",
              "protocol": "https",
              "host": ["identify-eu-west-1", "acrcloud", "com"],
              "path": ["v1", "identify"],
              "query": [],
              "variable": []
            },
            "header": [
              {
                "key": "Content-Type",
                "value": "multipart/form-data"
              }
            ],
            "method": "POST",
            "auth": null,
            "body": {
              "mode": "formdata",
              "formdata": [
                { "key": "sample", "type": "file", "src": [] },
                { "key": "sample_bytes", "type": "text", "value": "<integer>" },
                { "key": "access_key", "type": "text", "value": "{{accessKey}}" },
                { "key": "data_type", "type": "text", "value": "audio" },
                { "key": "signature_version", "type": "text", "value": "1" },
                { "key": "signature", "type": "text", "value": "{{signature}}" },
                { "key": "timestamp", "type": "text", "value": "{{timestamp}}" }
              ]
            }
          },
          "response": []
        }
      ]
    },
